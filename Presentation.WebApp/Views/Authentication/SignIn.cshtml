@{
    ViewData["Title"] = "Sign In";
}

<section id="sign-in-page">
    <div id="sign-in-form">
        <h1 class="title">Welcome Back!</h1>
        <p>
            Log in to continue your fitness journey with full access to your
            customized program, training history, and progress tracking. Stay
            consistent, monitor your development, and keep moving forward with the
            structure and support built into your account.
        </p>
        <hr />
        <div id="external-login-providers">
            <div class="login-provider-icon-border">
                <img src="~/images/google-icon.svg" alt="" />
            </div>
            <div class="login-provider-icon-border">
                <img src="~/images/github-icon.svg" alt="" />
            </div>
        </div>
        <p id="break-line-with-text">OR CONTINUE WITH</p>

        <form method="post">
            <div class="form-fields">
                <div class="form-field">
                    <label for="email-address">Email Address *</label>
                    <input type="text"
                           name="email-address"
                           id="email-address"
                           placeholder="Enter Email Address" />
                </div>
                <div class="form-field">
                    <div id="password-label-and-forgot-password">
                        <label for="password">Password *</label>
                        <a href="">Forgot Password?</a>
                    </div>
                    <input type="text"
                           name="password"
                           id="password"
                           placeholder="Enter Password" />
                </div>
            </div>
            <a href="" class="primary-button" id="sign-in-submit-btn">
                Continue
            </a>
            <div id="accept-utac-section">
                <input type="checkbox" name="accept-utac" id="accept-utac" />
                <label for="accept-utac">
                    Accept user terms and conditions
                </label>
            </div>
        </form>
    </div>
</section>