@{
    ViewData["Title"] = "My Account";
}
<h1 class="title my-account-title">My Account</h1>
<section id="my-account-section">
    <aside>
        <img src="~/images/account/trainer-1 1.png" alt="" />
        <div id="my-menu-options">
            <p id="menu-title">Menu options</p>
            <ul>
                <li>
                    <p>About me</p>
                    <hr />
                </li>
                <li>
                    <p>My memberships</p>
                    <hr />
                </li>
                <li>
                    <p>My Bookings</p>
                    <hr />
                </li>
                <li>
                    <p>Sign Out</p>
                </li>
            </ul>
        </div>
        <div id="cancel-section">
            <p>if you like to cancel your account, click below</p>
            <p>Remove account</p>
        </div>
    </aside>
    <div id="about-me-section">
        <form method="POST" novalidate>
            <p class="form-title">About Me</p>
            <hr />
            <div class="form-fields">
                <div class="form-field">
                    <label htmlFor="first-name">First Name *</label>
                    <input type="text"
                           name="first-name"
                           id="first-name"
                           placeholder="Enter First Name" />
                </div>
                <div class="form-field">
                    <label htmlFor="last-name">Last Name *</label>
                    <input type="text"
                           name="last-name"
                           id="last-name"
                           placeholder="Enter Last Name" />
                </div>
                <div class="form-field">
                    <label htmlFor="email">Email *</label>
                    <input type="text"
                           name="email"
                           id="email"
                           placeholder="Enter Email Address" />
                </div>
                <div class="form-field">
                    <label htmlFor="phone-number">Phone Number</label>
                    <input type="text"
                           name="phone-number"
                           id="phone-number"
                           placeholder="Enter Phone Number" />
                </div>
                <div class="form-field">
                    <label htmlFor="profile-img">Profile Image</label>
                    <div class="file-input-wrapper">
                        <span class="file-input-text" id="file-input-label">
                            Upload Profile Image
                        </span>
                        <input type="file"
                               name="profile-img"
                               id="profile-img"
                               hidden
                               onChange={(e) => {
                        const label = document.getElementById("file-input-label");
                        label.textContent =
                        e.target.files[0]?.name || "Upload Profile Image";
                        }}
                        />
                        <button type="button"
                                onClick={() =>
                            document.getElementById("profile-img").click()
                            }
                            >
                            Browse
                        </button>
                    </div>
                </div>
            </div>
            <input type="submit" value="Save" class="primary-button" />
        </form>

        <section id="my-statistics-section">
            <p class="my-statistics-title">My Statistics</p>
            <div id="progress-stats">
                <div class="progress-stat">
                    <p>Check-In (last 30 days)</p>
                    <p>25</p>
                </div>
                <div class="progress-stat">
                    <p>Weight Goal</p>
                    <p>50%</p>
                </div>
                <div class="progress-stat">
                    <p>Current BMI</p>
                    <p>27</p>
                </div>
            </div>
        </section>
    </div>
</section>