@{
}
<div id="footer-upper-section">
    <div id="footer-upper-section-left">
        <img src="~/images/logotype.svg" alt="" />
    </div>
    <div id="footer-upper-section-right">
        <p>Empowering Your Fitness Journey with Expert</p>
        <p>Training and Lasting Results</p>
    </div>
</div>
<hr />
<div id="footer-middle-section">
    <div id="footer-middle-section-left">
        <p id="our-location-title">Our location</p>
        <p id="location-info">
            Our supportive and knowledgeable trainers work with member to
            provide encourangement.
        </p>
        <img src="~/images/footer/footer-location-map 1.svg" alt="" id="location-map" />
        <p id="footer-address">
            2nd Floor, Wellness Center, Drottninggatan 118, Stockholm
        </p>
    </div>
    <div id="footer-middle-section-right">
        <div id="working-hours-section">
            <p id="working-hours-title">Working hours</p>
            <div id="working-hours">
                <p>Mon - Fri: 06:00 - 18:00</p>
                <p>Saturday: 10:00 - 18:00</p>
            </div>
        </div>
        <div id="opening-hours-section">
            <p id="opening-hours-title">Opening hours</p>
            <p>Mon - Sun: 04:00 - 23:00</p>
        </div>
    </div>
</div>
<hr />
<div id="footer-lower-section">
    <p>
        &copy; @DateTime.Now.Year Core Fitness Group. All Rights Reserved.
    </p>
</div>